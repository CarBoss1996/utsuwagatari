.admin-container.mt-4
  .container
    %h2.mb-4 ユーザー管理

    - @stores.each do |store|
      .mb-5
        .d-flex.align-items-center.mb-2
          %h5.me-auto= store.name
          = link_to "ユーザー追加", new_admin_store_user_path(store), class: "btn btn-outline-success btn-sm"

        - if store.users.any?
          %table.table.table-striped
            %thead
              %tr
                %th 名前
                %th 権限
                %th ステータス
                %th 作成日
                %th
            %tbody
              - store.users.order(role: :desc, created_at: :asc).each do |user|
                %tr
                  %td= user.name
                  %td= user.role
                  %td
                    - if user.active?
                      %span.badge.bg-success 有効
                    - else
                      %span.badge.bg-secondary 無効
                  %td= l user.created_at, format: :short
                  %td
                    = link_to "詳細", admin_user_path(user), class: "btn btn-outline-secondary btn-sm"
        - else
          %p.text-muted.small ユーザーなし
      != pagy_bootstrap_nav(@pagy) if @pagy.pages > 1
