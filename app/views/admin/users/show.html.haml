= content_for :headings do
  .article-header-nav
    %ul.nav.nav-pills{role: "tablist"}
      %li.nav-item
        %a.btn.btn-secondary{href: admin_users_path} 戻る
      %li.nav-item
        = link_to "編集", edit_admin_user_path(@user), class: "btn btn-outline-success"
      - unless @user == current_user
        %li.nav-item
          = button_to "削除", admin_user_path(@user), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: "本当に削除しますか？" }

.admin-container.mt-4
  .container
    %h2.mb-4 ユーザー詳細

    .card
      .card-body
        .row.mb-2
          .col-sm-3.fw-bold 店舗
          .col-sm-9= @user.store.name
        .row.mb-2
          .col-sm-3.fw-bold 名前
          .col-sm-9= @user.name
        .row.mb-2
          .col-sm-3.fw-bold 権限
          .col-sm-9= @user.role
        .row.mb-2
          .col-sm-3.fw-bold ステータス
          .col-sm-9
            - if @user.active?
              %span.badge.bg-success 有効
            - else
              %span.badge.bg-secondary 無効
        .row.mb-2
          .col-sm-3.fw-bold 作成日
          .col-sm-9= l @user.created_at, format: :long
