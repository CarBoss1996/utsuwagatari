= content_for :headings do
  -# .article-header-nav
  -#   %ul.nav.nav-pills{:role => "tablist"}
  -#     %li.nav-item
  -#       %a.btn.btn-secondary{href: owner_categories_path} 戻る

.owner-container.mt-4
  .container
    .title.d-flex.mb-2
      %h2.me-auto 保管場所一覧
      %button.btn.btn-outline-secondary.me-2{"data-bs-toggle" => "modal", "data-bs-target" => "#floorMapModal"} 配置図
      %a.btn.btn-outline-success.d-flex.align-items-center{href: new_owner_place_path} 新規登録

%div#floorMapModal.modal.fade{"tabindex" => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h5.modal-title 配置図
        %button.btn-close{"data-bs-dismiss" => "modal"}
      .modal-body
        = render "floor_map"

.owner-container
  .container
    %table.table.table-striped
      %thead
        %tr
          %th 名前
          %th ステータス
          %th.show
      %tbody
        - @places.each do |place|
          %tr
            %td= place.name
            %td
              - if place.active?
                %span.badge.bg-success 有効
              - else
                %span.badge.bg-secondary 無効
            %td.show
              %a.btn.btn-outline-secondary.btn-sm{href: owner_place_path(place)} 詳細
