= content_for :headings do
  -# .article-header-nav
  -#   %ul.nav.nav-pills{:role => "tablist"}
  -#     %li.nav-item
  -#       %a.btn.back{href: root_path} 戻る

.owner-container.mt-4
  .container
    .title.d-flex.mb-2
      %h2.me-auto うつわ一覧
      %a.btn.btn-outline-success{href: new_owner_tableware_path} 新規登録


    %table.table.table-striped
      %thead
        %tr
          %th
          %th 名前
          %th.show 有効/無効
          %th.show
      %tbody
        - @tablewares.each do |tableware|
          %tr
            %td
              - if tableware.images.attached?
                = image_tag url_for(tableware.images.first), class: "img-thumbnail", style: "width: 60px; height: 60px; object-fit: cover;"
              - else
                %div.img-placeholder.bg-secondary.text-white.d-flex.align-items-center.justify-content-center{ style: "width: 60px; height: 60px;" }
            %td
              = tableware.name
            %td
              = card_value tableware,:active, as: :boolean
            %td.show
              %a.btn.btn-outline-secondary{href: owner_tableware_path(tableware.id)} 詳細
