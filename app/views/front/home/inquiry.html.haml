.container.py-5
  %h2.mb-4 お問い合わせ
  = simple_form_for @inquiry, url: inquiry_path, method: :post, data: { turbo: false } do |f|
    = f.input :name, label: "お名前"
    = f.input :email, label: "メールアドレス"
    = f.input :body, as: :text, label: "お問い合わせ内容"
    = f.input :image, as: :file, label: "画像（任意）"
    = f.button :submit, "送信する", class: "btn mt-2"
