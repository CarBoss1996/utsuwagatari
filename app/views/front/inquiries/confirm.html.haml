.container.py-5
  %h2.mb-4 お問い合わせ内容の確認

  .card.mb-4
    .card-body
      .row.mb-2
        .col-4.fw-bold 内容
        .col-8= simple_format @inquiry.body
      - if @inquiry.image.attached?
        .row.mb-2
          .col-4.fw-bold 画像
          .col-8= image_tag @inquiry.image, style: "max-width: 200px"
      .row.mb-2
        .col-4.fw-bold メールアドレス
        .col-8= @inquiry.email.presence || "未入力"

  = form_with url: inquiries_path, method: :post, data: { turbo: false } do |f|
    = hidden_field_tag "inquiry[name]", @inquiry.name
    = hidden_field_tag "inquiry[email]", @inquiry.email
    = hidden_field_tag "inquiry[body]", @inquiry.body
    .d-flex.gap-2
      = link_to "戻る", new_inquiry_path, class: "btn btn-outline-secondary"
      = f.submit "送信する", class: "btn btn-primary"
