# ===== ローカル開発用 (.env) =====
# cp .env.example .env して、不要な行をコメントアウトする

# ローカルDBの設定（development.rb のデフォルトと合わせる場合は不要）
# DATABASE_URL=mysql2://root:password@127.0.0.1/utuwagatari_development

# ===== 本番・staging サーバー用 (shared/.env) =====

# データベース（VPS上のMySQL）
DATABASE_URL=mysql2://utuwagatari:YOUR_DB_PASSWORD@127.0.0.1/utuwagatari_production

# AWS S3（またはCloudflare R2）
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
AWS_REGION=ap-northeast-1
AWS_BUCKET=your-bucket-name
# AWS_ENDPOINT=  # Cloudflare R2 の場合のみ（https://xxx.r2.cloudflarestorage.com）

# 本番ドメイン
APP_HOST=utsuwagatari.com
