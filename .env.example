# このファイルをコピーして .env を作成し、本番サーバーの shared/ に配置する
# cp .env.example .env

# データベース（VPS上のMySQL）
DATABASE_URL=mysql2://utuwagatari:YOUR_DB_PASSWORD@127.0.0.1/utuwagatari_production

# AWS S3（またはCloudflare R2）
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
AWS_REGION=ap-northeast-1        # AWS S3 の場合のリージョン
AWS_BUCKET=your-bucket-name
# AWS_ENDPOINT=                  # Cloudflare R2 の場合のみ設定（https://xxx.r2.cloudflarestorage.com）

# 本番ドメイン（ワイルドカードサブドメインで使うドメイン）
APP_HOST=yourdomain.com
